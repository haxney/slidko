/.claude/
/.opencode/

# Regenerable test fixtures ONLY (deterministic sigrok-cli --driver demo output).
# Real hardware captures are irreplaceable evidence and MUST be committed — keep
# them out of this dir (in tests/fixtures/ directly, or in corpus/).
tests/fixtures/generated/

# Python
/.venv/
__pycache__/
*.egg-info/
.pytest_cache/
.ruff_cache/
/logs/

# Firmware: build tree(s) + runner-provisioned pico-sdk (regenerable; the SDK
# is large and is not our source — never commit it). Board builds use
# separate directories (build-pico, build-pico2) so both can coexist without
# reconfiguring; `/firmware/build*/` covers all of them plus the plain
# `firmware/build/` used for a single-board local run.
/firmware/build*/
/firmware/vendor/
/firmware/test/build/
